msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "가져온 메타데이터가 불완전할 수 있습니다. 게시 전에 확인하세요."

msgid "Add citations"
msgstr "인용 추가"

msgid "Paste / Import"
msgstr "붙여넣기 / 가져오기"

msgid "Manual Entry"
msgstr "직접 입력"

msgid "Add DOI(s), BibTeX entries, and citations in supported styles for books, articles, chapters, and webpages. Separate multiple formatted citations with a blank line."
msgstr "도서, 논문, 장, 웹페이지에 대해 지원되는 스타일로 DOI, BibTeX 항목 및 인용을 추가합니다. 여러 인용을 입력할 경우 빈 줄로 구분하세요."

msgid "Resolving…"
msgstr "확인 중…"

msgid "Add"
msgstr "추가"

msgid "Clear"
msgstr "지우기"

msgid "Author(s)"
msgstr "저자"

msgid "Title"
msgstr "제목"

msgid "Container"
msgstr "수록지"

msgid "Publisher"
msgstr "출판사"

msgid "Year"
msgstr "연도"

msgid "Pages"
msgstr "페이지"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "인용 입력 폼 숨기기"

msgid "Show citation form"
msgstr "인용 입력 폼 보기"

msgid "Settings"
msgstr "설정"

msgid "source"
msgstr "건"

msgid "sources"
msgstr "건"

msgid "Citation Style"
msgstr "인용 스타일"

msgid "Changing styles reformats auto-generated citations and keeps manual overrides intact."
msgstr "스타일을 변경하면 자동 생성된 인용이 재형식화되며, 직접 수정한 내용은 그대로 유지됩니다."

msgid "Visible Heading"
msgstr "표시 제목"

msgid "Optional heading shown above the bibliography on the site front end when at least one citation exists."
msgstr "인용이 하나 이상 있을 때 사이트 전면에서 참고문헌 목록 위에 표시되는 선택적 제목입니다."

msgid "Output JSON-LD"
msgstr "JSON-LD 출력"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "검색 엔진과 다른 도구가 참고문헌을 이해하는 데 도움이 됩니다."

msgid "Output COinS"
msgstr "COinS 출력"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Zotero 및 유사한 도구가 페이지에서 인용을 감지할 수 있게 합니다."

msgid "Output CSL-JSON"
msgstr "CSL-JSON 출력"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "학술 도구와 서비스에서 인용 데이터를 재사용할 수 있게 합니다."

msgid "Exports"
msgstr "내보내기"

msgid "Copy bibliography"
msgstr "참고문헌 복사"

msgid "Copies the current bibliography as plain text in the current order and style."
msgstr "현재 순서와 스타일로 참고문헌을 일반 텍스트로 복사합니다."

msgid "Download CSL-JSON"
msgstr "CSL-JSON 다운로드"

msgid "Downloads the current bibliography as structured citation data."
msgstr "참고문헌을 구조화된 인용 데이터로 다운로드합니다."

msgid "Download BibTeX"
msgstr "BibTeX 다운로드"

msgid "Downloads the current bibliography as BibTeX for reference-manager and scholarly-writing workflows."
msgstr "참고문헌을 문헌 관리 도구 및 학술 저작 워크플로에서 사용할 BibTeX 형식으로 다운로드합니다."

msgid "Download RIS"
msgstr "RIS 다운로드"

msgid "Downloads the current bibliography as RIS for citation managers and import/export workflows."
msgstr "참고문헌을 문헌 관리 도구 및 가져오기/내보내기 워크플로에서 사용할 RIS 형식으로 다운로드합니다."

msgid "Notification"
msgstr "알림"

msgid "Publication Type"
msgstr "자료 유형"

msgid "Select a publication type"
msgstr "자료 유형 선택"

msgid "Save"
msgstr "저장"

msgid "Cancel"
msgstr "취소"

msgid "Post not found."
msgstr "글을 찾을 수 없습니다."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "이 참고문헌을 열람할 권한이 없습니다."

msgid "Bibliography block not found for the requested index."
msgstr "요청한 인덱스에 해당하는 참고문헌 블록을 찾을 수 없습니다."

msgid "Post ID to inspect for bibliography blocks."
msgstr "참고문헌 블록을 검사할 글의 ID입니다."

msgid "Zero-based bibliography block index within the post."
msgstr "글 내에서 0부터 시작하는 참고문헌 블록 인덱스입니다."

msgid "Response format: json, text, or csl-json."
msgstr "응답 형식: json, text 또는 csl-json."
